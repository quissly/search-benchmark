# Copy to .env and fill in. Every variable the harness reads, no values.
# Keys are only needed to RE-RUN searches or judging; all published numbers
# recompute from the shipped judged data without any key.

# --- LLM judge (and query generation) ---
GEMINI_API_KEY=

# --- Catalog location (normalized parquet files, one per sector; see
#     catalogs/ scripts and DATA_LICENSES.md for how to rebuild them) ---
CATALOG_DIR=

# --- Quissly (endpoint of a deployment exposing /api/search) ---
QUISSLY_SEARCH_URL=

# --- Algolia (one app, per-sector indices named after the sectors) ---
APP_ID=
SEARCH_API_KEY=

# --- Doofinder (per-sector stores; some sectors on separate accounts with
#     their own API key — see SECTOR_CFG in providers.py) ---
DOOFINDER_API_KEY=
DOOFINDER_FAST_FASHION_HASH_ID=
DOOFINDER_ELECTRONICS_HASH_ID=
DOOFINDER_COSMETICS_HASH_ID=
DOOFINDER_FURNITURE_HASH_ID=
DOOFINDER_AUTO_HASH_ID=
DOOFINDER_MARKETPLACE_HASH_ID=
DOOFINDER_MARKETPLACE_API_KEY=
DOOFINDER_PHARMACY_HASH_ID=
DOOFINDER_PHARMACY_API_KEY=

# --- Luigi's Box (per-sector trackers) ---
LUIGISBOX_FAST_FASHION_TRACKER_ID=
LUIGISBOX_ELECTRONICS_TRACKER_ID=
LUIGISBOX_COSMETICS_TRACKER_ID=
LUIGISBOX_FURNITURE_TRACKER_ID=
LUIGISBOX_AUTO_TRACKER_ID=
LUIGISBOX_MARKETPLACE_TRACKER_ID=
LUIGISBOX_PHARMACY_TRACKER_ID=

# --- Clerk.io (per-sector stores; CLERK_PUBLIC_KEY is fast-fashion) ---
CLERK_PUBLIC_KEY=
CLERK_ELECTRONICS_PUBLIC_KEY=
CLERK_COSMETICS_PUBLIC_KEY=
CLERK_FURNITURE_PUBLIC_KEY=
CLERK_AUTO_PUBLIC_KEY=
CLERK_MARKETPLACE_PUBLIC_KEY=
CLERK_PHARMACY_PUBLIC_KEY=
